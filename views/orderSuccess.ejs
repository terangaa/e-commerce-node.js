<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('partials/head', { pageTitle: 'Commande confirmée - Ecommerce JIM' }) %>
</head>

<body>
  <%- include('partials/nav', { user, locale, currentPage: 'cart' }) %>

    <div class="container my-5">

      <div class="alert alert-success text-center">
        <h2 class="mb-3">Commande validée !</h2>

        <p>
          Merci <strong>
            <%= order.customerName %>
          </strong>,
          votre commande n°<strong>
            <%= order.id %>
          </strong> a bien été prise en compte.
        </p>

        <p>
          Un email de confirmation a été envoyé à
          <strong>
            <%= order.customerEmail %>
          </strong>.
        </p>

        <% if (emailStatus && emailStatus.customer==='failed' ) { %>
          <div class="alert alert-warning mt-3">
            <strong>Attention :</strong>
            l'envoi de l'email de confirmation a échoué.
          </div>
          <% } %>

            <p class="mb-3">
              Nous vous contacterons au <strong>
                <%= order.customerPhone %>
              </strong>.
            </p>

            <p class="mb-4">
              Total : <strong>
                <%= order.totalAmount %> FCFA
              </strong>
            </p>

            <% if (typeof ownerWhatsApp !=='undefined' && ownerWhatsApp) { %>
              <% const waMessage=encodeURIComponent( `Bonjour, je viens de passer la commande n°${order.id}. Montant:
                ${order.totalAmount} FCFA. Merci!` ); const waLink=`https://wa.me/${ownerWhatsApp}?text=${waMessage}`;
                %>

                <a href="<%= waLink %>" target="_blank" class="btn btn-success mb-3">
                  <i class="fab fa-whatsapp"></i> Contacter le vendeur sur WhatsApp
                </a>
                <br>
                <% } %>

                  <a href="/products" class="btn btn-primary">
                    Retour aux produits
                  </a>
      </div>

    </div>

    <%- include('partials/footer') %>

</body>

</html>