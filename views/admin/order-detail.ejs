<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Commande #<%= order.id %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            background: #0f172a;
            font-family: 'Segoe UI', sans-serif;
            color: #e2e8f0;
        }

        /* HEADER PREMIUM */
        .topbar {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .title {
            font-size: 20px;
            font-weight: 700;
            color: #fff;
        }

        /* CARDS */
        .card-modern {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 18px;
            padding: 18px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
            transition: 0.3s;
        }

        .card-modern:hover {
            transform: translateY(-4px);
            border-color: rgba(59, 130, 246, 0.4);
        }

        /* BADGES MODERNES */
        .badge-status {
            padding: 8px 14px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .5px;
            text-transform: uppercase;
        }

        .pending {
            background: #facc15;
            color: #1f2937;
        }

        .confirmed {
            background: #60a5fa;
            color: #0f172a;
        }

        .completed {
            background: #34d399;
            color: #052e16;
        }

        .cancelled {
            background: #fb7185;
            color: #fff;
        }

        /* INFO BOX */
        .info-box {
            background: rgba(255, 255, 255, 0.05);
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 10px;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        /* TABLE PREMIUM */
        table {
            width: 100%;
            border-radius: 12px;
            overflow: hidden;
        }

        thead {
            background: #1e293b;
            color: #fff;
        }

        tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            transition: 0.2s;
        }

        tbody tr:hover {
            background: rgba(59, 130, 246, 0.08);
        }

        /* TOTAL CARD */
        .total-box {
            background: linear-gradient(135deg, #3b82f6, #06b6d4);
            padding: 18px;
            border-radius: 16px;
            font-size: 20px;
            font-weight: 700;
            color: white;
            text-align: right;
            box-shadow: 0 10px 25px rgba(59, 130, 246, 0.25);
        }

        /* BUTTON */
        .btn-back {
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
        }

        .btn-back:hover {
            background: rgba(59, 130, 246, 0.2);
            color: #fff;
        }

        h5 {
            color: #fff;
            font-weight: 700;
        }

        /* RESPONSIVE MOBILE */
        @media (max-width: 767px) {
            body {
                padding: 0;
                margin: 0;
                min-height: 100vh;
                width: 100%;
                overflow-x: hidden;
            }

            .container {
                max-width: 100%;
                width: 100%;
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 12px;
                margin-left: 0;
                margin-right: 0;
            }

            .topbar {
                flex-direction: column;
                gap: 12px;
                text-align: center;
                padding: 14px;
                width: 100%;
                border-radius: 12px;
                margin-bottom: 15px;
            }

            .row {
                margin-left: 0;
                margin-right: 0;
            }

            .col-md-4, .col-md-8 {
                width: 100%;
                padding-left: 0;
                padding-right: 0;
                margin-bottom: 15px;
            }

            .title {
                font-size: 16px;
                order: 1;
            }

            .topbar .btn-back {
                order: 2;
                width: 100%;
            }

            .badge-status {
                order: 3;
            }

            .card-modern {
                padding: 14px;
            }

            .table-responsive {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }

            table {
                font-size: 12px;
                min-width: 400px;
            }

            table th, table td {
                padding: 8px 6px;
                white-space: nowrap;
            }

            .total-box {
                text-align: center;
                font-size: 16px;
                padding: 14px;
            }

            .btn-action-mobile {
                width: 100%;
                margin-bottom: 8px;
            }

            .info-box {
                font-size: 13px;
            }

            .btn-back {
                font-size: 14px;
            }

            .info-box b {
                display: inline-block;
                min-width: 70px;
            }
        }
    </style>
</head>

<body>

    <div class="container py-4">

        <!-- HEADER -->
        <div class="topbar">

            <a href="/admin/orders" class="btn btn-back">
                <i class="fa fa-arrow-left"></i> Retour
            </a>

            <div class="title">
                Commande #<%= order.id %>
            </div>

            <span class="badge-status
      <%= order.status === 'pending' ? 'pending' :
          order.status === 'confirmed' ? 'confirmed' :
          order.status === 'completed' ? 'completed' : 'cancelled' %>">

                <%= order.status %>

            </span>

        </div>

        <div class="row g-4">

            <!-- CLIENT -->
            <div class="col-md-4">
                <div class="card-modern">

                    <h5><i class="fa fa-user text-info"></i> Client</h5>

                    <div class="info-box"><b>Nom :</b>
                        <%= order.customerName %>
                    </div>
                    <div class="info-box"><b>Email :</b>
                        <%= order.customerEmail %>
                    </div>
                    <div class="info-box"><b>Téléphone :</b>
                        <%= order.customerPhone %>
                    </div>
                    <div class="info-box"><b>Adresse :</b>
                        <%= order.deliveryAddress || 'Non définie' %>
                    </div>

                </div>
            </div>

            <!-- PRODUITS -->
            <div class="col-md-8">

                <div class="card-modern">

                    <h5><i class="fa fa-box text-info"></i> Produits</h5>

                    <% if (order.OrderItems && order.OrderItems.length> 0) { %>

                        <div class="table-responsive">
                        <table class="mt-3">
                            <thead>
                                <tr>
                                    <th>Produit</th>
                                    <th>Quantité</th>
                                    <th>Prix</th>
                                    <th>Total</th>
                                </tr>
                            </thead>

                            <tbody>
                                <% order.OrderItems.forEach(item=> { %>
                                    <tr>
                                        <td><b>
                                                <%= item.Product?.name || 'Produit supprimé' %>
                                            </b></td>
                                        <td>
                                            <%= item.quantity %>
                                        </td>
                                        <td>
                                            <%= item.unitPrice %> FCFA
                                        </td>
                                        <td><b>
                                                <%= item.unitPrice * item.quantity %> FCFA
                                            </b></td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                        </div>

                        <% } else { %>
                            <p class="text-muted">Aucun produit</p>
                            <% } %>

                </div>

                <!-- TOTAL -->
                <div class="total-box mt-3">
                    TOTAL : <%= order.totalAmount %> FCFA
                </div>

            </div>

        </div>

        <div class="d-grid d-md-flex gap-2 mt-3">
            <a href="/admin/orders/<%= order.id %>/invoice" class="btn btn-success btn-action-mobile">
                📄 Télécharger facture
            </a>

            <a href="/admin/orders/<%= order.id %>/send-invoice" class="btn btn-primary btn-action-mobile">
                📧 Envoyer par email
            </a>
        </div>



    </div>



</body>

</html>