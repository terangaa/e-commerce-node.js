<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Paramètres - JIM Shopping</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        :root {
            --primary: #FF6A00;
            --primary-light: #ff8533;
            --dark-bg: #0a0f1c;
            --card-bg: #111827;
            --border-color: rgba(255, 255, 255, 0.06);
            --text-primary: #e5e7eb;
            --text-muted: #94a3b8;
            --accent: #3b82f6;
        }

        * {
            box-sizing: border-box;
            max-width: 100vw;
        }

        html, body {
            overflow-x: hidden;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--dark-bg);
            color: var(--text-primary);
            font-family: 'Segoe UI', sans-serif;
            font-size: 14px;
            line-height: 1.6;
        }

        /* SIDEBAR - Desktop */
        .sidebar {
            background: #0f172a;
            height: 100vh;
            width: 260px;
            position: fixed;
            padding: 20px;
            border-right: 1px solid var(--border-color);
            z-index: 100;
            transition: transform 0.3s ease;
        }

        .sidebar h4 {
            font-weight: bold;
            margin-bottom: 20px;
            color: var(--primary);
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 6px;
            transition: 0.3s;
            font-size: 0.9rem;
        }

        .sidebar a:hover, .sidebar a.active {
            background: rgba(255, 106, 0, 0.1);
            color: var(--primary);
        }

        .sidebar a.active {
            border-left: 3px solid var(--primary);
        }

        /* Mobile Menu Button */
        .mobile-toggle {
            display: none;
            position: fixed;
            top: 15px;
            left: 15px;
            z-index: 101;
            width: 45px;
            height: 45px;
            background: var(--primary);
            border: none;
            border-radius: 10px;
            color: white;
            font-size: 1.2rem;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(255, 106, 0, 0.3);
        }

        .mobile-toggle:hover {
            background: var(--primary-light);
        }

        /* Sidebar Overlay */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            z-index: 99;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .sidebar-overlay.active {
            opacity: 1;
        }

        /* CONTENT */
        .content {
            margin-left: 260px;
            padding: 30px;
            max-width: 100%;
        }

        /* HEADER */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .page-title {
            font-size: 1.5rem;
            font-weight: bold;
            color: white;
            margin: 0;
        }

        .page-subtitle {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-top: 5px;
        }

        /* CARDS */
        .card-modern {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
            max-width: 100%;
        }

        .section-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 15px;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-modern p {
            color: var(--text-muted);
            font-size: 0.9rem;
            line-height: 1.7;
            margin-bottom: 12px;
        }

        .card-modern ul {
            padding-left: 20px;
            color: var(--text-muted);
        }

        .card-modern li {
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        /* BADGE */
        .badge-soft {
            background: rgba(255, 106, 0, 0.15);
            padding: 8px 14px;
            border-radius: 10px;
            font-size: 0.75rem;
            color: var(--primary);
            display: inline-block;
            margin-top: 10px;
        }

        /* INPUTS */
        .form-group {
            margin-bottom: 15px;
        }

        .form-label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .input-dark {
            background: #0b1220;
            border: 1px solid #1f2937;
            color: white;
            border-radius: 10px;
            padding: 12px 15px;
            width: 100%;
            outline: none;
            font-size: 0.9rem;
            transition: border-color 0.3s;
        }

        .input-dark:focus {
            border-color: var(--primary);
        }

        /* BUTTON */
        .btn-save {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            border: none;
            padding: 14px 28px;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 106, 0, 0.3);
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            /* Hide sidebar on mobile */
            .sidebar {
                transform: translateX(-100%);
                width: 80%;
                max-width: 280px;
            }

            .sidebar.mobile-open {
                transform: translateX(0);
            }

            /* Show mobile toggle */
            .mobile-toggle {
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* Show overlay */
            .sidebar-overlay {
                display: block;
            }

            /* Adjust content */
            .content {
                margin-left: 0;
                padding: 20px 15px;
                padding-top: 70px;
            }

            /* Page header */
            .page-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .page-title {
                font-size: 1.3rem;
            }

            /* Cards */
            .card-modern {
                padding: 15px;
                margin-bottom: 15px;
                border-radius: 12px;
            }

            .section-title {
                font-size: 0.95rem;
            }

            .card-modern p {
                font-size: 0.85rem;
            }

            /* Forms */
            .form-row {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            .form-row > div {
                width: 100% !important;
            }

            .input-dark {
                padding: 12px;
                font-size: 0.85rem;
            }

            /* Button */
            .btn-save {
                width: 100%;
                justify-content: center;
                padding: 14px;
            }
        }

        @media (max-width: 480px) {
            body {
                font-size: 13px;
            }

            .content {
                padding: 15px 10px;
                padding-top: 65px;
            }

            .page-title {
                font-size: 1.1rem;
            }

            .card-modern {
                padding: 12px;
            }

            .input-dark {
                padding: 10px;
            }
        }
    </style>
</head>

<body>

    <!-- Mobile Toggle Button -->
    <button class="mobile-toggle" onclick="toggleSidebar()">
        <i class="fa fa-bars"></i>
    </button>

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <h4>⚙️ JIM Admin</h4>

        <a href="/admin/dashboard"><i class="fa fa-home"></i> Dashboard</a>
        <a href="/admin/orders"><i class="fa fa-box"></i> Commandes</a>
        <a href="/admin/products"><i class="fa fa-cube"></i> Produits</a>
        <a href="/admin/users"><i class="fa fa-users"></i> Utilisateurs</a>
        <a href="/admin/settings" class="active"><i class="fa fa-gear"></i> Paramètres</a>
        <a href="/"><i class="fa fa-store"></i> Voir boutique</a>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- HEADER -->
        <div class="page-header">
            <div>
                <h1 class="page-title">⚙️ Paramètres système</h1>
                <p class="page-subtitle">Gestion complète de votre boutique e-commerce</p>
            </div>
        </div>

        <form method="POST" action="/admin/settings">

        <!-- ABOUT -->
        <div class="card-modern">
            <div class="section-title">📌 À propos</div>

            <p>
                JIM Shopping est une plateforme e-commerce spécialisée dans la vente en ligne
                de produits du quotidien tels que les valises, draps, jalabis et autres articles divers.
            </p>

            <p>
                Nous offrons une expérience d'achat simple, rapide et sécurisée avec des produits
                de qualité et un service client fiable.
            </p>

            <span class="badge-soft">E-commerce • Produits • Livraison</span>
        </div>

        <!-- SERVICES -->
        <div class="card-modern">
            <div class="section-title">🛠️ Services</div>

            <ul>
                <li>🛒 Vente de produits en ligne</li>
                <li>🚚 Livraison rapide</li>
                <li>💳 Paiement sécurisé</li>
                <li>📦 Suivi des commandes</li>
                <li>📞 Support client</li>
            </ul>
        </div>

        <!-- WHATSAPP -->
        <div class="card-modern">
            <div class="section-title">💬 WhatsApp Propriétaire</div>

            <div class="form-row">
                <div class="col-md-6">
                    <label class="form-label">Numéro WhatsApp (sans +, ex: 221770000000)</label>
                    <input class="input-dark" name="ownerWhatsApp" value="<%= settings.ownerWhatsApp || '' %>" placeholder="221770000000">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Message de commande auto</label>
                    <input class="input-dark" value="Nouvelle commande reçue" readonly>
                </div>
            </div>
        </div>

        <!-- SETTINGS -->
        <div class="card-modern">
            <div class="section-title">🏪 Configuration boutique</div>

            <div class="form-row">
                <div class="col-md-6">
                    <label class="form-label">Nom boutique</label>
                    <input class="input-dark" name="shopName" value="<%= settings.shopName || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Adresse</label>
                    <input class="input-dark" name="shopAddress" value="<%= settings.shopAddress || '' %>">
                </div>
            </div>

            <div class="form-row">
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input class="input-dark" name="contactEmail" value="<%= settings.contactEmail || '' %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Téléphone</label>
                    <input class="input-dark" name="contactPhone" value="<%= settings.contactPhone || '' %>">
                </div>
            </div>
        </div>

        <button type="submit" class="btn-save">
            💾 Sauvegarder les paramètres
        </button>

    </form>

    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('active');
        }

        // Close sidebar when clicking outside
        document.getElementById('sidebarOverlay')?.addEventListener('click', () => {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('active');
        });
    </script>

</body>

</html>