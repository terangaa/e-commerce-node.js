<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Paramètres - ALMANA SHOP</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            background: #0a0f1c;
            color: #e5e7eb;
            font-family: 'Segoe UI', sans-serif;
        }

        /* SIDEBAR */
        .sidebar {
            background: #0f172a;
            height: 100vh;
            width: 260px;
            position: fixed;
            padding: 25px;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

        .sidebar h4 {
            font-weight: bold;
            margin-bottom: 20px;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            color: #94a3b8;
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 6px;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background: #1e293b;
            color: #fff;
        }

        /* CONTENT */
        .content {
            margin-left: 280px;
            padding: 35px;
        }

        /* CARDS */
        .card-modern {
            background: #111827;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 18px;
            padding: 22px;
            margin-bottom: 20px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        }

        .title {
            font-size: 24px;
            font-weight: bold;
        }

        .subtitle {
            color: #94a3b8;
        }

        /* INPUTS */
        .input-dark {
            background: #0b1220;
            border: 1px solid #1f2937;
            color: white;
            border-radius: 12px;
            padding: 12px;
            width: 100%;
            outline: none;
        }

        .input-dark:focus {
            border-color: #3b82f6;
        }

        /* BUTTON */
        .btn-save {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            padding: 12px 20px;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-save:hover {
            transform: translateY(-2px);
        }

        /* BADGE */
        .badge-soft {
            background: #1f2937;
            padding: 6px 12px;
            border-radius: 10px;
            font-size: 12px;
            color: #93c5fd;
        }

        /* SECTION TITLE */
        .section-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #60a5fa;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>⚙️ Admin Panel</h4>

        <a href="/admin/dashboard"><i class="fa fa-home"></i> Dashboard</a>
        <a href="/admin/orders"><i class="fa fa-box"></i> Commandes</a>
        <a href="/admin/products"><i class="fa fa-cube"></i> Produits</a>
        <a href="/admin/users"><i class="fa fa-users"></i> Utilisateurs</a>
        <a href="/admin/settings"><i class="fa fa-gear"></i> Paramètres</a>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- HEADER -->
        <div class="card-modern">
            <div class="title">⚙️ Paramètres système</div>
            <div class="subtitle">Gestion complète de votre boutique e-commerce</div>
        </div>

        <!-- ABOUT -->
        <div class="card-modern">
            <div class="section-title">📌 À propos</div>

            <p>
                ALMANA SHOP est une plateforme e-commerce spécialisée dans la vente en ligne
                de produits du quotidien tels que les valises, draps, jalabis et autres articles divers.
            </p>

            <p>
                Nous offrons une expérience d’achat simple, rapide et sécurisée avec des produits
                de qualité et un service client fiable.
            </p>

            <span class="badge-soft">E-commerce • Produits • Livraison</span>
        </div>

        <!-- SERVICES -->
        <div class="card-modern">
            <div class="section-title">🛠️ Services</div>

            <ul>
                <li>🛒 Vente de produits en ligne</li>
                <li>🚚 Livraison rapide</li>
                <li>💳 Paiement sécurisé</li>
                <li>📦 Suivi des commandes</li>
                <li>📞 Support client</li>
            </ul>
        </div>

        <!-- CONTACT -->
        <div class="card-modern">
            <div class="section-title">📞 Contact</div>

            <div class="row">
                <div class="col-md-6">
                    <label>Email</label>
                    <input class="input-dark" value="contact@almana-shop.com">
                </div>

                <div class="col-md-6">
                    <label>Téléphone</label>
                    <input class="input-dark" value="+221 71 142 67 56">
                </div>
            </div>
        </div>

        <!-- SETTINGS -->
        <div class="card-modern">
            <div class="section-title">🏪 Configuration boutique</div>

            <div class="row">
                <div class="col-md-6">
                    <label>Nom boutique</label>
                    <input class="input-dark" value="ALMANA SHOP">
                </div>

                <div class="col-md-6">
                    <label>Adresse</label>
                    <input class="input-dark" value="Dakar, Sénégal">
                </div>
            </div>
        </div>

        <button class="btn-save mt-3">
            💾 Sauvegarder les paramètres
        </button>

    </div>

</body>

</html>