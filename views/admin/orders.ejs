<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopify SaaS Admin</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Inter, sans-serif;
      background: linear-gradient(135deg, #eef2ff, #f8fafc);
      color: #0f172a;
    }

    /* ================= SIDEBAR ================= */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: 280px;
      height: 100%;
      background: linear-gradient(180deg, #0b1220, #111827);
      padding: 22px;
      transition: .35s ease;
      z-index: 1000;
      box-shadow: 10px 0 40px rgba(0, 0, 0, 0.3);
    }

    .sidebar.show {
      transform: translateX(0);
    }

    .brand {
      font-size: 18px;
      font-weight: 700;
      color: white;
      margin-bottom: 25px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      margin: 8px 0;
      border-radius: 12px;
      text-decoration: none;
      color: #cbd5e1;
      transition: .25s;
      font-weight: 500;
    }

    .sidebar a i {
      width: 20px;
      text-align: center;
      color: #94a3b8;
    }

    .sidebar a:hover {
      background: rgba(99, 102, 241, 0.15);
      color: white;
      transform: translateX(5px);
    }

    /* ================= OVERLAY ================= */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      display: none;
      z-index: 900;
    }

    .overlay.show {
      display: block;
    }

    /* ================= TOPBAR ================= */
    .topbar {
      position: sticky;
      top: 0;
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(12px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 18px;
      z-index: 800;
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .mobile-menu-btn {
      display: none;
      width: 40px;
      height: 40px;
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #64748b;
      font-size: 1.1rem;
      flex-shrink: 0;
      transition: all 0.2s;
    }

    .mobile-menu-btn:hover {
      background: #4f46e5;
      color: white;
      border-color: #4f46e5;
    }

    .menu-btn {
      display: none;
    }

    @media(max-width: 1023px) {
      .mobile-menu-btn {
        display: flex;
      }

      .menu-btn {
        display: none;
      }

      .topbar-title {
        font-size: 1rem;
      }

      .stats {
        grid-template-columns: repeat(2, 1fr);
      }

      .card {
        padding: 12px;
      }

      .item {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }

      .item-left {
        width: 100%;
      }
    }

    /* ================= CONTENT ================= */
    .content {
      padding: 16px;
    }

    /* ================= STATS ================= */
    .stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }

    .stat {
      background: white;
      padding: 14px;
      border-radius: 16px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
    }

    .stat h4 {
      font-size: 12px;
      color: gray;
    }

    .stat p {
      font-size: 20px;
      font-weight: 700;
      margin-top: 5px;
    }

    /* ================= CARD ================= */
    .card {
      background: white;
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 14px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
      transition: .2s;
    }

    .card:hover {
      transform: translateY(-3px);
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    /* ================= STATUS ================= */
    .status {
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
    }

    .pending {
      background: #fff7ed;
      color: #f59e0b;
    }

    .confirmed {
      background: #eff6ff;
      color: #3b82f6;
    }

    .shipped {
      background: #ecfeff;
      color: #06b6d4;
    }

    .completed {
      background: #ecfdf5;
      color: #10b981;
    }

    .cancelled {
      background: #fef2f2;
      color: #ef4444;
    }

    /* ================= ITEM ================= */
    .item {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      align-items: center;
    }

    .item-left {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .item img {
      width: 45px;
      height: 45px;
      border-radius: 10px;
      object-fit: cover;
    }

    .price {
      font-weight: 700;
      color: #4f46e5;
    }

    select,
    button {
      width: 100%;
      padding: 10px;
      margin-top: 10px;
      border-radius: 10px;
    }

    select {
      border: 1px solid #e5e7eb;
    }

    button {
      border: none;
      background: #4f46e5;
      color: white;
      font-weight: 600;
      cursor: pointer;
    }

    button:hover {
      background: #4338ca;
    }

    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      display: none;
      z-index: 900;
    }

    .overlay.show {
      display: block;
    }

    @media(max-width: 1023px) {
      .sidebar {
        transform: translateX(-100%);
      }

      .sidebar.show {
        transform: translateX(0);
      }

      .main-content {
        margin-left: 0;
      }

      .mobile-menu-btn {
        display: flex !important;
        width: 40px;
        height: 40px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #64748b;
        font-size: 1.1rem;
        flex-shrink: 0;
      }

      .stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media(min-width: 1024px) {
      .sidebar {
        left: 0;
      }

      .content {
        margin-left: 280px;
      }

      .menu-btn {
        display: none;
      }

      .stats {
        grid-template-columns: repeat(4, 1fr);
      }

      .overlay {
        display: none !important;
      }
    }
  </style>
</head>

<body>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="brand">
      ⚡ Shopify SaaS
    </div>

    <a href="/admin/dashboard"><i class="fa fa-chart-line"></i> Dashboard</a>
    <a href="/admin/orders"><i class="fa fa-cart-shopping"></i> Commandes</a>
    <a href="/admin/products/add"><i class="fa fa-box"></i> Produits</a>
    <a href="/admin/users"><i class="fa fa-users"></i> Utilisateurs</a>
  </div>

  <div class="overlay" onclick="toggleMenu()"></div>

  <!-- TOPBAR -->
  <div class="topbar">
    <button class="mobile-menu-btn" onclick="toggleMenu()">
      <i class="fa fa-bars"></i>
    </button>

    <strong>Orders Dashboard</strong>
    <i class="fa fa-bell"></i>
  </div>

  <!-- CONTENT -->
  <div class="content">

    <!-- STATS -->
    <div class="stats">
      <div class="stat">
        <h4>Total</h4>
        <p>
          <%= orders.length %>
        </p>
      </div>

      <div class="stat">
        <h4>En attente</h4>
        <p>
          <%= orders.filter(o=>o.status==='pending').length %>
        </p>
      </div>

      <div class="stat">
        <h4>Livrées</h4>
        <p>
          <%= orders.filter(o=>o.status==='completed').length %>
        </p>
      </div>

      <div class="stat">
        <h4>Annulées</h4>
        <p>
          <%= orders.filter(o=>o.status==='cancelled').length %>
        </p>
      </div>
    </div>

    <!-- ORDERS -->
    <% orders.forEach(order=> { %>

      <div class="card">

        <div class="header">
          <strong>#<%= order.id %></strong>

          <span class="status <%= order.status %>">
            <%= order.status %>
          </span>
        </div>

        <p>
          <%= order.customerName %>
        </p>
        <small>
          <%= order.customerEmail %>
        </small><br>

        <small style="color:gray;">
          <%= order.createdAt ? new Date(order.createdAt).toLocaleString('fr-FR') : '' %>
        </small>

        <hr>

        <% (order.OrderItems || []).forEach(item=> { %>

          <div class="item">
            <div class="item-left">
              <img src="<%= item.Product?.imageUrl || 'https://via.placeholder.com/50' %>">

              <div>
                <div>
                  <%= item.Product?.name || 'Produit' %>
                </div>
                <small>x<%= item.quantity %></small>
              </div>
            </div>

            <div class="price">
              <%= item.unitPrice %> FCFA
            </div>
          </div>

          <% }) %>

            <form method="post" action="/admin/orders/<%= order.id %>/status">
              <select name="status">
                <option value="pending">Pending</option>
                <option value="confirmed">Confirmed</option>
                <option value="shipped">Shipped</option>
                <option value="completed">Completed</option>
                <option value="cancelled">Cancelled</option>
              </select>

              <button>Mettre à jour</button>
            </form>

      </div>

      <% }) %>

  </div>

  <script>
    function toggleMenu() {
      document.querySelector('.sidebar').classList.toggle('show');
      document.querySelector('.overlay').classList.toggle('show');
    }
  </script>

</body>

</html>