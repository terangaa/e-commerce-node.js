<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Commandes — Admin Ecommerce</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --bg: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
      --surface: #ffffff;
      --surface2: #f8fafc;
      --surface3: #f1f5f9;
      --border: rgba(148, 163, 184, 0.1);
      --border-hover: rgba(59, 130, 246, 0.2);
      --accent: #2563eb;
      --accent-light: #eff6ff;
      --accent-hover: #1d4ed8;
      --accent2: #0ea5e9;
      --accent3: #8b5cf6;
      --text: #0f172a;
      --text-secondary: #475569;
      --muted: #64748b;
      --muted-light: #94a3b8;
      --success: #10b981;
      --success-light: #d1fae5;
      --danger: #ef4444;
      --danger-light: #fee2e2;
      --warning: #f59e0b;
      --warning-light: #fef3c7;
      --info: #06b6d4;
      --info-light: #cffafe;
      --sidebar-w: 280px;
      --radius: 16px;
      --radius-sm: 8px;
      --radius-lg: 24px;
      --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      --shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
      --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      --transition-fast: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
      --transition-slow: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* Modern Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: var(--surface3);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--muted-light);
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: var(--muted);
    }

    /* Sidebar */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      z-index: 100;
      transition: var(--transition);
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    .sidebar-header {
      padding: 24px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
      color: white;
    }

    .sidebar-logo {
      font-family: 'Syne', sans-serif;
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .sidebar-subtitle {
      font-size: 14px;
      opacity: 0.9;
    }

    .sidebar-nav {
      flex: 1;
      padding: 16px 0;
      overflow-y: auto;
    }

    .nav-section-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 16px 24px 8px;
      margin-bottom: 8px;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      padding: 12px 24px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: var(--transition-fast);
      border-radius: 0 24px 24px 0;
      margin: 2px 8px 2px 0;
      position: relative;
    }

    .sidebar a:hover {
      background: var(--surface2);
      color: var(--text);
      transform: translateX(4px);
    }

    .sidebar a.active {
      background: var(--accent-light);
      color: var(--accent);
      font-weight: 500;
    }

    .sidebar a.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: var(--accent);
      border-radius: 0 4px 4px 0;
    }

    .nav-label {
      margin-left: 12px;
      font-size: 15px;
    }

    /* Main Content */
    .main-content {
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Topbar */
    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: var(--shadow-sm);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .topbar-title {
      font-family: 'Syne', sans-serif;
      font-size: 28px;
      font-weight: 700;
      color: var(--text);
      margin: 0;
    }

    .topbar-sub {
      font-size: 16px;
      color: var(--muted);
      margin: 4px 0 0 0;
    }

    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .icon-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: var(--radius-sm);
      color: var(--muted);
      text-decoration: none;
      transition: var(--transition-fast);
      position: relative;
    }

    .icon-btn:hover {
      background: var(--surface2);
      color: var(--text);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    /* Content */
    .content {
      flex: 1;
      padding: 32px;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    /* Cards */
    .card {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: var(--transition);
      margin-bottom: 24px;
    }

    .card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .card-header {
      padding: 24px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(135deg, var(--surface2) 0%, var(--surface3) 100%);
    }

    .card-title {
      font-family: 'Syne', sans-serif;
      font-size: 24px;
      font-weight: 700;
      color: var(--text);
      margin: 0 0 8px 0;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .card-subtitle {
      color: var(--muted);
      font-size: 16px;
      margin: 0;
    }

    .card-body {
      padding: 24px;
    }

    /* Filters */
    .filters-card {
      margin-bottom: 32px;
    }

    .filters-form {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      align-items: end;
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    .form-label {
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-input, .form-select {
      padding: 16px;
      border: 2px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 16px;
      transition: var(--transition-fast);
      background: var(--surface);
      color: var(--text);
    }

    .form-input:focus, .form-select:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .btn {
      padding: 16px 24px;
      border: none;
      border-radius: var(--radius-sm);
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition-fast);
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      text-align: center;
      justify-content: center;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
      color: white;
      box-shadow: var(--shadow);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    /* Stats Overview */
    .stats-overview {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      text-align: center;
      transition: var(--transition);
    }

    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .stat-card-icon {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 24px;
      margin: 0 auto 16px;
    }

    .stat-card-icon.pending { background: linear-gradient(135deg, var(--warning) 0%, #fbbf24 100%); }
    .stat-card-icon.confirmed { background: linear-gradient(135deg, var(--info) 0%, #0891b2 100%); }
    .stat-card-icon.shipped { background: linear-gradient(135deg, var(--accent2) 0%, #0284c7 100%); }
    .stat-card-icon.completed { background: linear-gradient(135deg, var(--success) 0%, #059669 100%); }
    .stat-card-icon.cancelled { background: linear-gradient(135deg, var(--danger) 0%, #dc2626 100%); }
    .stat-card-icon.total { background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%); }

    .stat-card-value {
      font-size: 36px;
      font-weight: 700;
      color: var(--text);
      margin: 0 0 8px 0;
    }

    .stat-card-label {
      font-size: 16px;
      color: var(--muted);
      margin: 0;
      font-weight: 500;
    }

    /* Orders Grid */
    .orders-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .order-card {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: var(--transition);
      position: relative;
    }

    .order-card:hover {
      box-shadow: var(--shadow-lg);
      transform: translateY(-4px);
    }

    .order-header {
      padding: 20px;
      background: linear-gradient(135deg, var(--surface2) 0%, var(--surface3) 100%);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }

    .order-info {
      display: flex;
      align-items: center;
      gap: 16px;
      flex: 1;
    }

    .order-id {
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
      margin: 0;
    }

    .order-customer {
      color: var(--muted);
      font-size: 14px;
      margin: 4px 0 0 0;
    }

    .order-meta {
      display: flex;
      gap: 16px;
      align-items: center;
      flex-wrap: wrap;
    }

    .order-date, .order-total {
      font-size: 14px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .order-status {
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .order-status.pending { background: var(--warning-light); color: var(--warning); }
    .order-status.confirmed { background: var(--info-light); color: var(--info); }
    .order-status.shipped { background: rgba(14, 165, 233, 0.1); color: var(--accent2); }
    .order-status.completed { background: var(--success-light); color: var(--success); }
    .order-status.cancelled { background: var(--danger-light); color: var(--danger); }

    .order-actions {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .order-body {
      padding: 0;
    }

    .order-details {
      padding: 20px;
      border-bottom: 1px solid var(--border);
    }

    .customer-details {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 20px;
    }

    .detail-item {
      display: flex;
      flex-direction: column;
    }

    .detail-label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }

    .detail-value {
      font-size: 16px;
      color: var(--text);
      font-weight: 500;
    }

    .order-items {
      background: var(--surface2);
      padding: 20px;
    }

    .order-items-title {
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
      margin: 0 0 16px 0;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .order-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }

    .order-item:last-child {
      border-bottom: none;
    }

    .item-info {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1;
    }

    .item-image {
      width: 50px;
      height: 50px;
      border-radius: var(--radius-sm);
      background: var(--surface3);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 20px;
      flex-shrink: 0;
      overflow: hidden;
      position: relative;
    }

    .item-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: var(--radius-sm);
      transition: var(--transition-fast);
    }

    .item-image img:hover {
      transform: scale(1.1);
    }

    .image-fallback {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 20px;
    }

    .item-details h4 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
      margin: 0 0 4px 0;
    }

    .item-meta {
      font-size: 14px;
      color: var(--muted);
    }

    .item-price {
      font-weight: 600;
      color: var(--accent);
    }

    .order-footer {
      padding: 20px;
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }

    .status-form {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .status-select {
      padding: 10px 16px;
      border: 2px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 14px;
      background: var(--surface);
      color: var(--text);
      min-width: 140px;
    }

    .status-select:focus {
      outline: none;
      border-color: var(--accent);
    }

    .order-total-large {
      font-size: 24px;
      font-weight: 700;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 80px 20px;
      color: var(--muted);
    }

    .empty-icon {
      font-size: 64px;
      margin-bottom: 24px;
      opacity: 0.5;
    }

    .empty-title {
      font-family: 'Syne', sans-serif;
      font-size: 24px;
      font-weight: 600;
      color: var(--text);
      margin: 0 0 8px 0;
    }

    .empty-text {
      font-size: 16px;
      margin: 0;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .sidebar {
        transform: translateX(-100%);
      }

      .main-content {
        margin-left: 0;
      }

      .sidebar.show {
        transform: translateX(0);
      }
    }

    @media (max-width: 768px) {
      .content {
        padding: 16px;
      }

      .topbar {
        padding: 16px;
      }

      .topbar-title {
        font-size: 24px;
      }

      .filters-form {
        grid-template-columns: 1fr;
      }

      .order-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .order-meta {
        width: 100%;
        justify-content: space-between;
      }

      .customer-details {
        grid-template-columns: 1fr;
      }

      .stats-overview {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .card, .order-card, .stat-card {
      animation: fadeInUp 0.5s ease-out;
    }
  </style>
</head>

<body>
  <!-- Sidebar -->
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">Ecommerce JIM</div>
      <div class="sidebar-subtitle">Administration</div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section-title">Catalogue</div>
      <a href="/admin/dashboard?tab=products">
        <i class="fa fa-box"></i><span class="nav-label">Produits</span>
      </a>
      <a href="/admin/dashboard?tab=categories">
        <i class="fa fa-tags"></i><span class="nav-label">Catégories</span>
      </a>

      <div class="nav-section-title">Gestion</div>
      <a href="/admin/orders" class="active">
        <i class="fa fa-shopping-cart"></i><span class="nav-label">Commandes</span>
      </a>
      <a href="/admin/users">
        <i class="fa fa-users"></i><span class="nav-label">Utilisateurs</span>
      </a>
    </nav>
  </div>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <div>
          <h1 class="topbar-title">Commandes</h1>
          <div class="topbar-sub">Suivez et gérez vos commandes</div>
        </div>
      </div>
      <div class="topbar-actions">
        <a href="#" class="icon-btn" title="Notifications">
          <i class="fa fa-bell"></i>
        </a>
        <a href="/auth/logout" class="icon-btn" title="Déconnexion">
          <i class="fa fa-right-from-bracket"></i>
        </a>
      </div>
    </div>

    <!-- Content -->
    <div class="content">
      <!-- Stats Overview -->
      <div class="stats-overview">
        <div class="stat-card">
          <div class="stat-card-icon total">
            <i class="fa fa-shopping-cart"></i>
          </div>
          <div class="stat-card-value"><%= orders ? orders.length : 0 %></div>
          <div class="stat-card-label">Commandes totales</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon pending">
            <i class="fa fa-clock"></i>
          </div>
          <div class="stat-card-value"><%= orders ? orders.filter(o => o.status === 'pending').length : 0 %></div>
          <div class="stat-card-label">En attente</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon confirmed">
            <i class="fa fa-check-circle"></i>
          </div>
          <div class="stat-card-value"><%= orders ? orders.filter(o => o.status === 'confirmed').length : 0 %></div>
          <div class="stat-card-label">Confirmées</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon completed">
            <i class="fa fa-check-double"></i>
          </div>
          <div class="stat-card-value"><%= orders ? orders.filter(o => o.status === 'completed').length : 0 %></div>
          <div class="stat-card-label">Terminées</div>
        </div>
      </div>

      <!-- Filters -->
      <div class="card filters-card">
        <div class="card-header">
          <h2 class="card-title">
            <i class="fa fa-filter"></i>
            Filtres
          </h2>
          <p class="card-subtitle">Filtrer les commandes par statut et période</p>
        </div>
        <div class="card-body">
          <form method="get" action="/admin/orders" class="filters-form">
            <div class="form-group">
              <label class="form-label" for="status">Statut</label>
              <select name="status" id="status" class="form-select">
                <option value="">Tous les statuts</option>
                <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>En attente</option>
                <option value="confirmed" <%= status === 'confirmed' ? 'selected' : '' %>>Confirmée</option>
                <option value="shipped" <%= status === 'shipped' ? 'selected' : '' %>>Expédiée</option>
                <option value="completed" <%= status === 'completed' ? 'selected' : '' %>>Terminée</option>
                <option value="cancelled" <%= status === 'cancelled' ? 'selected' : '' %>>Annulée</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="from">Date de début</label>
              <input type="date" name="from" id="from" value="<%= from || '' %>" class="form-input">
            </div>
            <div class="form-group">
              <label class="form-label" for="to">Date de fin</label>
              <input type="date" name="to" id="to" value="<%= to || '' %>" class="form-input">
            </div>
            <div class="form-group">
              <label class="form-label">&nbsp;</label>
              <button type="submit" class="btn btn-primary">
                <i class="fa fa-search"></i>
                Appliquer les filtres
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Orders List -->
      <% if (!orders || orders.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">
            <i class="fa fa-shopping-cart"></i>
          </div>
          <h2 class="empty-title">Aucune commande trouvée</h2>
          <p class="empty-text">Il n'y a pas de commandes correspondant à vos critères de recherche.</p>
        </div>
      <% } else { %>
        <div class="orders-grid">
          <% orders.forEach(order => { %>
            <div class="order-card">
              <div class="order-header">
                <div class="order-info">
                  <div>
                    <h3 class="order-id">Commande #<%= order.id %></h3>
                    <p class="order-customer"><%= order.customerName %></p>
                  </div>
                </div>
                <div class="order-meta">
                  <div class="order-date">
                    <i class="fa fa-calendar"></i>
                    <%= new Date(order.createdAt).toLocaleDateString('fr-FR') %>
                  </div>
                  <div class="order-total">
                    <i class="fa fa-euro-sign"></i>
                    <%= order.totalAmount %> FCFA
                  </div>
                  <div class="order-status <%= order.status %>">
                    <%= order.status === 'pending' ? 'En attente' :
                        order.status === 'confirmed' ? 'Confirmée' :
                        order.status === 'shipped' ? 'Expédiée' :
                        order.status === 'completed' ? 'Terminée' : 'Annulée' %>
                  </div>
                </div>
              </div>

              <div class="order-body">
                <div class="order-details">
                  <div class="customer-details">
                    <div class="detail-item">
                      <span class="detail-label">Email</span>
                      <span class="detail-value"><%= order.customerEmail %></span>
                    </div>
                    <div class="detail-item">
                      <span class="detail-label">Téléphone</span>
                      <span class="detail-value"><%= order.customerPhone %></span>
                    </div>
                    <div class="detail-item">
                      <span class="detail-label">Adresse</span>
                      <span class="detail-value"><%= order.deliveryAddress || 'Non spécifiée' %></span>
                    </div>
                    <div class="detail-item">
                      <span class="detail-label">Mode de paiement</span>
                      <span class="detail-value"><%= order.paymentMethod || 'Non spécifié' %></span>
                    </div>
                  </div>
                </div>

                <div class="order-items">
                  <h4 class="order-items-title">
                    <i class="fa fa-box"></i>
                    Articles commandés
                  </h4>
                  <% if (order.OrderItems && order.OrderItems.length > 0) { %>
                    <% order.OrderItems.forEach(item => { %>
                      <div class="order-item">
                        <div class="item-info">
                          <div class="item-image">
                            <% if (item.Product && item.Product.imageUrl) { %>
                              <img src="/public<%= item.Product.imageUrl %>"
                                   alt="<%= item.Product.name %>"
                                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                              <div class="image-fallback" style="display: none;">
                                <i class="fa fa-box"></i>
                              </div>
                            <% } else { %>
                              <i class="fa fa-box"></i>
                            <% } %>
                          </div>
                          <div class="item-details">
                            <h4><%= item.Product ? item.Product.name : 'Produit #' + item.productId %></h4>
                            <div class="item-meta">Quantité: <%= item.quantity %></div>
                          </div>
                        </div>
                        <div class="item-price"><%= item.unitPrice %> FCFA</div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <p style="color: var(--muted); margin: 0;">Aucun article trouvé pour cette commande.</p>
                  <% } %>
                </div>

                <div class="order-footer">
                  <form method="post" action="/admin/orders/<%= order.id %>/status" class="status-form">
                    <label for="status-<%= order.id %>" style="font-weight: 600; color: var(--text);">Changer le statut:</label>
                    <select name="status" id="status-<%= order.id %>" class="status-select">
                      <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>En attente</option>
                      <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Confirmée</option>
                      <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Expédiée</option>
                      <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Terminée</option>
                      <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Annulée</option>
                    </select>
                    <button type="submit" class="btn btn-primary">
                      <i class="fa fa-save"></i>
                      Mettre à jour
                    </button>
                  </form>
                  <div class="order-total-large">
                    <i class="fa fa-euro-sign"></i>
                    <%= order.totalAmount %> FCFA
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    // Add some interactive effects
    document.addEventListener('DOMContentLoaded', function() {
      // Add hover effects to order cards
      const orderCards = document.querySelectorAll('.order-card');
      orderCards.forEach(card => {
        card.addEventListener('mouseenter', function() {
          this.style.transform = 'translateY(-8px) scale(1.01)';
        });
        card.addEventListener('mouseleave', function() {
          this.style.transform = 'translateY(0) scale(1)';
        });
      });

      // Form validation feedback
      const inputs = document.querySelectorAll('.form-input, .form-select');
      inputs.forEach(input => {
        input.addEventListener('blur', function() {
          if (this.value.trim() !== '') {
            this.classList.add('valid');
          } else {
            this.classList.remove('valid');
          }
        });
      });

      // Status change confirmation
      const statusForms = document.querySelectorAll('.status-form');
      statusForms.forEach(form => {
        form.addEventListener('submit', function(e) {
          const select = this.querySelector('.status-select');
          const newStatus = select.options[select.selectedIndex].text;
          if (!confirm(`Êtes-vous sûr de vouloir changer le statut de cette commande à "${newStatus}" ?`)) {
            e.preventDefault();
          }
        });
      });
    });
  </script>
</body>

</html>