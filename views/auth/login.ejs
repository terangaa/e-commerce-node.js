<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('../partials/head', { pageTitle: 'Connexion' }) %>
</head>
<body>
  <%- include('../partials/nav', { user, locale, currentPage: 'auth' }) %>
  <div class="container d-flex justify-content-center align-items-center auth-form-container" style="min-height: 100vh; padding: 2rem 1rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="card shadow-lg w-100 glass" style="max-width: 480px; border: none; backdrop-filter: blur(20px);">
      <div class="card-body p-3 p-md-5">
        <div class="text-center mb-4">
          <h2 class="mb-3 gradient-text" style="font-size: 2.5rem; font-weight: 700;">Connexion</h2>
          <p class="text-muted">Connectez-vous à votre compte</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger animate__animated animate__shake" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i><%= error %>
          </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success animate__animated animate__bounceIn" role="alert">
            <i class="fas fa-check-circle me-2"></i><%= success %>
          </div>
        <% } %>

        <form method="post" action="/auth/login" class="animate__animated animate__fadeInUp">
          <div class="mb-4">
            <label for="email" class="form-label fw-semibold">
              <i class="fas fa-envelope me-2 text-primary"></i>Email
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light border-end-0">
                <i class="fas fa-envelope text-muted"></i>
              </span>
              <input type="email" id="email" name="email" class="form-control border-start-0 ps-0"
                     placeholder="votre@email.com" required
                     value="<%= typeof email !== 'undefined' ? email : '' %>"
                     style="border-left: none; box-shadow: none;">
            </div>
          </div>

          <div class="mb-4">
            <label for="password" class="form-label fw-semibold">
              <i class="fas fa-lock me-2 text-primary"></i>Mot de passe
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light border-end-0">
                <i class="fas fa-lock text-muted"></i>
              </span>
              <input type="password" id="password" name="password" class="form-control border-start-0 ps-0"
                     placeholder="Votre mot de passe" required
                     style="border-left: none; box-shadow: none;">
            </div>
          </div>

          <div class="d-grid mb-4">
            <button type="submit" class="btn btn-primary btn-lg hover-lift"
                    style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; padding: 1rem;">
              <i class="fas fa-sign-in-alt me-2"></i>Se connecter
            </button>
          </div>
        </form>

        <div class="text-center">
          <p class="mb-2">
            <a href="/auth/forgot-password" class="text-decoration-none hover-scale">
              <i class="fas fa-key me-1"></i>Mot de passe oublié ?
            </a>
          </p>
          <p class="mb-0">
            Pas de compte ?
            <a href="/auth/register" class="text-decoration-none fw-semibold hover-scale"
               style="color: #667eea;">
              <i class="fas fa-user-plus me-1"></i>Inscrivez-vous
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>