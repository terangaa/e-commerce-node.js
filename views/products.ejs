<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('partials/head', { pageTitle: 'Liste des produits - Ecommerce JIM' }) %>
</head>
<body>
  <%- include('partials/nav', { user, locale, currentPage: 'products' }) %>

  <div class="container my-5">
    <h1 class="section-title">
      <%= selectedCategoryId ? categories.find(c => c.id === selectedCategoryId)?.name || __('product_list') : __('product_list') %>
    </h1>
    <p class="text-muted">
      <%= selectedCategoryId ? 'Découvrez tous nos produits de cette catégorie.' : 'Explorez nos produits et commandez rapidement en quelques clics.' %>
    </p>

    <form method="get" action="/products" class="mb-4">
      <div class="row">
        <div class="col-md-6 mb-2">
          <input type="text" name="q" class="form-control" placeholder="Rechercher un produit..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" />
        </div>
        <div class="col-md-4 mb-2">
          <select name="categoryId" class="form-control">
            <option value="">Toutes les catégories</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.id %>" <%= selectedCategoryId === c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2 mb-2">
          <button class="btn btn-primary w-100"><i class="fa fa-search"></i> Rechercher</button>
        </div>
      </div>
    </form>
    <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
      <div class="alert alert-info">
        Résultats pour "<strong><%= searchQuery %></strong>" - <%= products.length %> produit(s) trouvé(s)
        <a href="/products" class="btn btn-sm btn-outline-secondary ms-2">Réinitialiser</a>
      </div>
    <% } %>

    <div class="row">
      <% products.forEach(function(product){ %>
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="card h-100 shadow-sm">
            <% if(product.imageUrl){ %>
              <img src="<%= product.imageUrl %>" class="card-img-top" alt="<%= product.name %>" />
            <% } else { %>
              <img src="https://via.placeholder.com/320x180?text=<%= product.name %>" class="card-img-top" alt="<%= product.name %>" />
            <% } %>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= product.name %></h5>
              <p class="text-secondary mb-2">Catégorie : <%= product.Category ? product.Category.name : 'Non définie' %></p>
              <p class="card-text text-muted"><%= product.description ? product.description.substring(0, 80) + (product.description.length > 80 ? '...' : '') : 'Aucune description' %></p>
              <p class="font-weight-bold mb-2"><%= __('price') %> : <%= product.price %> FCFA</p>
              <p class="mb-3"><%= __('stock') %> : <strong><%= product.stock %></strong></p>
              <a href="/products/<%= product.id %>?lang=<%= locale %>" class="btn btn-primary mt-auto">Voir le produit</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <%- include('partials/footer') %>

