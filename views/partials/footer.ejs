<!-- FOOTER PREMIUM JIM -->
<footer class="footer-modern text-white position-relative overflow-hidden">

  <style>
    .footer-modern{
      background: radial-gradient(circle at top left, #111827, #0b1220 60%, #050814);
      padding-top: 70px;
      margin-top: 80px;
    }

    .footer-modern h5{
      font-weight: 700;
      margin-bottom: 18px;
      color: #ffb347;
      letter-spacing: 0.5px;
    }

    .footer-modern a{
      color: #cbd5e1;
      text-decoration: none;
      display: block;
      margin-bottom: 8px;
      transition: 0.3s ease;
    }

    .footer-modern a:hover{
      color: #ff6a00;
      transform: translateX(5px);
    }

    .footer-logo{
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 15px;
    }

    .footer-logo img{
      height: 55px;
      width: 55px;
      border-radius: 14px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.4);
    }

    .footer-desc{
      color: #94a3b8;
      font-size: 14px;
      line-height: 1.6;
    }

    .social-icons a{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255,255,255,0.06);
      margin-right: 8px;
      transition: 0.3s;
    }

    .social-icons a:hover{
      background: #ff6a00;
      transform: translateY(-4px);
    }

    .footer-bottom{
      background: rgba(0,0,0,0.6);
      padding: 15px 0;
      margin-top: 40px;
      text-align: center;
      font-size: 13px;
      color: #94a3b8;
    }

    .newsletter-box{
      background: rgba(255,255,255,0.05);
      padding: 15px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .newsletter-box input{
      border: none;
      outline: none;
      padding: 10px;
      width: 100%;
      border-radius: 10px;
      margin-bottom: 10px;
    }

    .newsletter-box button{
      width: 100%;
      background: linear-gradient(135deg,#ff6a00,#ff8c33);
      border: none;
      padding: 10px;
      border-radius: 10px;
      color: white;
      font-weight: 600;
    }
  </style>

  <div class="container">

    <div class="row g-4 py-5">

      <!-- LOGO -->
      <div class="col-lg-4 col-md-6">
        <div class="footer-logo">
          <img src="/public/uploads/logos.jpeg" alt="JIM">
          <h4 class="fw-bold text-warning mb-0">JIM Shopping</h4>
        </div>

        <p class="footer-desc">
          Boutique e-commerce moderne au Sénégal avec livraison rapide,
          produits de qualité et service client 24/7.
        </p>

        <!-- SOCIAL -->
        <div class="social-icons mt-3">
          <a href="#"><i class="fab fa-facebook-f"></i></a>
          <a href="#"><i class="fab fa-whatsapp"></i></a>
          <a href="#"><i class="fab fa-instagram"></i></a>
          <a href="#"><i class="fab fa-tiktok"></i></a>
        </div>
      </div>

      <!-- NAVIGATION -->
      <div class="col-lg-2 col-md-6">
        <h5>Navigation</h5>
        <a href="/">Accueil</a>
        <a href="/products">Produits</a>
        <a href="/categories">Catégories</a>
        <a href="/contact">Contact</a>
      </div>

      <!-- COMPTE -->
      <div class="col-lg-2 col-md-6">
        <h5>Compte</h5>
        <a href="/auth/login">Connexion</a>
        <a href="/auth/register">Inscription</a>
        <a href="/profile">Profil</a>
        <a href="/orders">Commandes</a>
      </div>

      <!-- NEWSLETTER -->
      <div class="col-lg-4 col-md-6">
        <h5>Newsletter</h5>
        <p class="footer-desc">
          Recevez nos offres exclusives directement par email.
        </p>

        <div class="newsletter-box">
          <form>
            <input type="email" placeholder="Votre email">
            <button type="submit">S'inscrire</button>
          </form>
        </div>

        <div class="mt-3">
          <p class="footer-desc">
            📍 Dakar, Sénégal<br>
            📞 +221 76 595 74 81<br>
            ✉️ contact@jimshopping.com
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- BOTTOM -->
  <div class="footer-bottom">
    &copy; <%= new Date().getFullYear() %> JIM Shopping - Tous droits réservés
  </div>

</footer>