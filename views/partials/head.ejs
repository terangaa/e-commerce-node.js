<link rel="stylesheet" href="/public/css/advanced-effects.css" />
<link rel="stylesheet" href="/public/css/modern.css" />

<style>
    /* ✅ Corrige uniquement les champs de formulaire */
    form input,
    form select,
    form textarea,
    form button {
        pointer-events: auto !important;
        position: relative !important;
        z-index: 1000 !important;
    }

    /* ✅ Assure visibilité correcte */
    form .form-control,
    form .form-select {
        opacity: 1 !important;
        background-color: #fff !important;
    }

    /* ✅ Corrige les overlays qui bloquent */
    .overlay,
    .effect-layer,
    .animation-layer {
        pointer-events: none !important;
    }
</style>