<% const _user=typeof user !=='undefined' ? user : null; const _locale=typeof locale !=='undefined' ? locale : 'fr' ;
  const _currentPage=typeof currentPage !=='undefined' ? currentPage : '' ; const _cartCount=typeof cartCount
  !=='undefined' ? cartCount : 0; const _cartItems=typeof cartItems !=='undefined' ? cartItems : []; const
  _totalAmount=typeof totalAmount !=='undefined' ? totalAmount : 0; %>

  <% if (!(_user && _user.role==='admin' )) { %>

    <nav class="navbar navbar-expand-xl navbar-light bg-white shadow-sm">
      <div class="container-fluid px-2 px-md-4">

        <a class="navbar-brand d-flex align-items-center" href="/">
          <img src="/public/uploads/logos.jpeg" style="height:40px;width:40px;border-radius:8px;">
          <span class="fw-bold ms-2">JIM Shopping</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">

          <ul class="navbar-nav me-auto">

            <li class="nav-item">
              <a class="nav-link <%= _currentPage === 'home' ? 'active' : '' %>" href="/">Accueil</a>
            </li>

            <li class="nav-item">
              <a class="nav-link <%= _currentPage === 'products' ? 'active' : '' %>" href="/products">Produits</a>
            </li>

            <!-- CART -->
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="/products/cart" data-bs-toggle="dropdown">
                🛒 (<%= _cartCount %>)
              </a>

              <ul class="dropdown-menu dropdown-menu-end">

                <% if (_cartItems && _cartItems.length> 0) { %>

                  <% _cartItems.slice(0,3).forEach(function(item) { %>

                    <li class="dropdown-item d-flex align-items-center">

                      <% if (item.product && item.product.imageUrl) { %>
                        <img src="/public/<%= item.product.imageUrl %>" style="width:40px;height:40px;">
                        <% } else { %>
                          <img src="https://via.placeholder.com/40">
                          <% } %>

                            <div class="ms-2 flex-grow-1">
                              <div>
                                <%= item.product ? item.product.name : 'Produit supprimé' %>
                              </div>
                              <small>
                                <%= item.quantity %> x <%= item.product ? item.product.price : 0 %>
                              </small>
                            </div>

                            <button class="btn btn-sm btn-danger"
                              onclick="removeFromCart(<%= item.product ? item.product.id : 0 %>)">
                              X
                            </button>

                    </li>

                    <% }); %>

                      <li>
                        <hr>
                      </li>
                      <li class="dropdown-item">
                        Total: <%= _totalAmount %> Fcfa
                      </li>

                      <% } else { %>
                        <li class="dropdown-item text-center">Panier vide</li>
                        <% } %>

              </ul>
            </li>

          </ul>

          <ul class="navbar-nav">

            <li class="nav-item">
              <a href="?lang=<%= _locale === 'fr' ? 'en' : 'fr' %>">
                <%= _locale==='fr' ? 'EN' : 'FR' %>
              </a>
            </li>

            <% if (_user) { %>
              <li class="nav-item">Bonjour <%= _user.name %>
              </li>
              <li class="nav-item"><a href="/auth/logout">Logout</a></li>
              <% } else { %>
                <li class="nav-item"><a href="/auth/login">Login</a></li>
                <% } %>

          </ul>

        </div>
      </div>
    </nav>

    <script>
      function removeFromCart(productId) {
        fetch('/products/cart/remove', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'productId=' + productId
        }).then(() => location.reload());
      }
    </script>

    <% } %>