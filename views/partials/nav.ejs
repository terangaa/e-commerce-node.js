<%
const _user = typeof user !== 'undefined' ? user : null;
const _locale = typeof locale !== 'undefined' ? locale : 'fr';
const _currentPage = typeof currentPage !== 'undefined' ? currentPage : '';
const _cartCount = typeof cartCount !== 'undefined' ? cartCount : 0;
const _cartItems = typeof cartItems !== 'undefined' ? cartItems : [];
const _totalAmount = typeof totalAmount !== 'undefined' ? totalAmount : 0;
%>

<% if (!(_user && _user.role === 'admin')) { %>

<style>
  .navbar-modern {
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .brand-modern {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.2rem;
    color: #ff6a00;
    text-decoration: none;
  }

  .brand-modern img {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    box-shadow: 0 6px 18px rgba(255,106,0,0.25);
  }

  .nav-link {
    font-weight: 500;
    position: relative;
    transition: 0.3s;
  }

  .nav-link:hover {
    color: #ff6a00 !important;
    transform: translateY(-1px);
  }

  .nav-link.active {
    color: #ff6a00 !important;
    font-weight: 700;
  }

  .nav-link.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 10%;
    width: 80%;
    height: 2px;
    background: #ff6a00;
    border-radius: 10px;
  }

  .cart-badge {
    background: linear-gradient(135deg,#ff6a00,#ff8533);
    color: white;
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 12px;
    margin-left: 5px;
  }

  .btn-modern {
    border-radius: 30px;
    padding: 6px 16px;
    font-weight: 600;
    transition: 0.3s;
  }

  .btn-modern:hover {
    transform: translateY(-2px);
  }

  .dropdown-menu {
    border-radius: 16px;
    border: none;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
  }

  .cart-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 0;
  }

  .cart-item img {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    object-fit: cover;
  }

  .cart-total {
    font-weight: 800;
    text-align: right;
    padding: 8px 0;
  }
</style>

<nav class="navbar navbar-expand-xl navbar-light navbar-modern shadow-sm sticky-top">
  <div class="container-fluid px-3">

    <!-- BRAND -->
    <a class="brand-modern" href="/">
      <img src="/public/uploads/logos.jpeg" alt="logo">
      <span>JIM Shopping</span>
    </a>

    <!-- MOBILE -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMain">

      <!-- LEFT MENU -->
      <ul class="navbar-nav me-auto gap-2">

        <li class="nav-item">
          <a class="nav-link <%= _currentPage === 'home' ? 'active' : '' %>" href="/">Accueil</a>
        </li>

        <li class="nav-item">
          <a class="nav-link <%= _currentPage === 'products' ? 'active' : '' %>" href="/products">
            Produits
          </a>
        </li>

        <!-- CART -->
        <li class="nav-item dropdown">
          <a class="nav-link" data-bs-toggle="dropdown" href="/products/cart">
            🛒 <span class="cart-badge"><%= _cartCount %></span>
          </a>

          <ul class="dropdown-menu dropdown-menu-end p-3" style="min-width:320px;">

            <% if (_cartItems.length > 0) { %>

              <% _cartItems.slice(0,3).forEach(item => { %>

                <li class="cart-item">
                  <% if (item.product && item.product.imageUrl) { %>
                    <img src="/public/<%= item.product.imageUrl %>">
                  <% } else { %>
                    <img src="https://via.placeholder.com/40">
                  <% } %>

                  <div style="flex:1;">
                    <div style="font-size:13px;font-weight:600;">
                      <%= item.product ? item.product.name : 'Produit' %>
                    </div>
                    <small class="text-muted">
                      <%= item.quantity %> x <%= item.product ? item.product.price : 0 %> Fcfa
                    </small>
                  </div>

                  <button class="btn btn-sm btn-danger"
                    onclick="removeFromCart('<%= item.product ? item.product.id : 0 %>')">
                    ×
                  </button>
                </li>

              <% }) %>

              <hr>

              <div class="cart-total">
                Total: <%= _totalAmount %> Fcfa
              </div>

              <a href="/products/cart" class="btn btn-primary w-100 btn-modern mt-2">
                Voir panier
              </a>

            <% } else { %>
              <p class="text-center text-muted mb-0">Panier vide</p>
            <% } %>

          </ul>
        </li>

      </ul>

      <!-- RIGHT -->
      <ul class="navbar-nav align-items-center gap-2">

        <!-- LANGUAGE -->
        <li class="nav-item">
          <a class="nav-link" href="?lang=<%= _locale === 'fr' ? 'en' : 'fr' %>">
            <%= _locale === 'fr' ? 'EN' : 'FR' %>
          </a>
        </li>

        <!-- USER -->
        <% if (_user) { %>
          <li class="nav-item">
            <span class="nav-link">Bonjour <strong><%= _user.name %></strong></span>
          </li>

          <li class="nav-item">
            <a href="/auth/logout" class="btn btn-outline-danger btn-modern">
              Logout
            </a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a href="/auth/login" class="btn btn-outline-primary btn-modern">
              Login
            </a>
          </li>
        <% } %>

      </ul>

    </div>
  </div>
</nav>

<script>
function removeFromCart(productId) {
  fetch('/products/cart/remove', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'productId=' + encodeURIComponent(productId)
  }).then(() => location.reload());
}
</script>

<% } %>