<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> - JIM Shopping</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  <!-- Bootstrap + Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    /* 🌈 BACKGROUND ULTRA MODERNE */
    body {
      font-family: Inter;
      background: radial-gradient(circle at top left, #ffd6a5 0%, transparent 35%),
                  radial-gradient(circle at bottom right, #bae6fd 0%, transparent 40%),
                  linear-gradient(180deg, #f8fafc, #eef2ff);
      min-height: 100vh;
      color: #0f172a;
    }

    .glass {
      background: rgba(255,255,255,0.75);
      backdrop-filter: blur(12px);
      border-radius: 22px;
      padding: 12px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.05);
    }

    .cardx {
      background: white;
      border-radius: 22px;
      padding: 25px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.06);
    }

    .img-box {
      background: white;
      border-radius: 22px;
      padding: 20px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.06);
    }

    .img-box img {
      width: 100%;
      height: 450px;
      object-fit: contain;
      transition: .4s;
    }

    .img-box:hover img {
      transform: scale(1.06);
    }

    .title {
      font-size: 30px;
      font-weight: 800;
    }

    .price {
      font-size: 38px;
      font-weight: 800;
      color: #ff6a00;
    }

    .badgex {
      background: #dcfce7;
      color: #15803d;
      padding: 5px 12px;
      border-radius: 50px;
      font-size: 12px;
      font-weight: 600;
    }

    .qty {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .qty button {
      width: 42px;
      height: 42px;
      border-radius: 10px;
      border: 1px solid #eee;
      background: white;
    }

    /* 🔥 INFO GRID */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(2,1fr);
      gap: 12px;
      margin-top: 15px;
    }

    .info-box {
      background: #f8fafc;
      padding: 12px;
      border-radius: 12px;
      font-size: 13px;
    }

    /* 🌙 FOOTER MODERNE */
    footer {
      margin-top: 60px;
      background: linear-gradient(135deg, #0f172a, #1e293b);
      color: white;
      padding: 50px 0;
    }

    footer a {
      color: #cbd5e1;
      text-decoration: none;
      display: block;
      margin-bottom: 6px;
      transition: .2s;
    }

    footer a:hover {
      color: #ff6a00;
      transform: translateX(5px);
    }

    .footer-title {
      font-weight: 700;
      margin-bottom: 12px;
    }
  </style>
</head>

<body>

<%- include('partials/nav', { user, locale }) %>

<div class="container py-5">

  <!-- breadcrumb -->
  <div class="glass mb-4">
    <a href="/">Accueil</a> /
    <a href="/products">Produits</a> /
    <b><%= product.name %></b>
  </div>

  <div class="row g-4">

    <!-- IMAGE -->
    <div class="col-lg-6">
      <div class="img-box">
        <img id="mainImg" src="<%= product.imageUrl %>">
      </div>
    </div>

    <!-- INFO -->
    <div class="col-lg-6">
      <div class="cardx">

        <h1 class="title"><%= product.name %></h1>

        <div class="price"><%= product.price %> FCFA</div>

        <span class="badgex mt-2 d-inline-block">🚚 Livraison rapide 24-72h</span>

        <p class="text-muted mt-3"><%= product.description %></p>

        <!-- 📊 DETAILS SUPPLÉMENTAIRES -->
        <div class="info-grid">
          <div class="info-box">📦 SKU: PRD-<%= product.id %></div>
          <div class="info-box">📍 Stock: <%= product.stock %></div>
          <div class="info-box">🔒 Paiement sécurisé</div>
          <div class="info-box">↩ Retour 7 jours</div>
        </div>

        <!-- QTY -->
        <div class="qty mt-3">
          <button onclick="qty(-1)">-</button>
          <input id="q" value="1" readonly>
          <button onclick="qty(1)">+</button>
        </div>

        <!-- BTN -->
        <form method="POST" action="/products/cart/add">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <input type="hidden" name="quantity" id="qtyInput" value="1">

          <button class="btn btn-primary w-100 mt-3">
            <i class="fa fa-cart-plus me-2"></i> Ajouter au panier
          </button>
        </form>

      </div>
    </div>

  </div>

  <!-- ⭐ AVIS -->
  <div class="cardx mt-4">
    <h5>⭐ Avis clients</h5>
    <p>⭐⭐⭐⭐⭐ 4.8/5</p>
    <p>“Très bon produit 👍” - Awa</p>
    <p>“Livraison rapide et propre” - Mamadou</p>
  </div>

</div>

<!-- 🌙 FOOTER COMPLET -->
<footer>
  <div class="container">
    <div class="row">

      <div class="col-md-4">
        <h5 class="footer-title">JIM Shopping</h5>
        <p>Votre boutique moderne, rapide et sécurisée au Sénégal.</p>
      </div>

      <div class="col-md-4">
        <h6 class="footer-title">Navigation</h6>
        <a href="/">Accueil</a>
        <a href="/products">Produits</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="col-md-4">
        <h6 class="footer-title">Support</h6>
        <a href="#">FAQ</a>
        <a href="#">Livraison</a>
        <a href="#">Retour produit</a>
        <a href="#">Conditions</a>
      </div>

    </div>

    <hr style="opacity:.1">

    <p class="text-center text-muted">
      © 2026 JIM Shopping — Tous droits réservés
    </p>
  </div>
</footer>

<script>
function qty(v){
  let q=document.getElementById('q');
  let val=parseInt(q.value)+v;
  if(val<1) val=1;
  q.value=val;
  document.getElementById('qtyInput').value=val;
}
</script>

</body>
</html>