<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('partials/head', { pageTitle: product.name }) %>
</head>

<body>

  <%- include('partials/nav', { user, locale, currentPage: 'products' }) %>

    <div class="container my-5">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/">Accueil</a></li>
          <li class="breadcrumb-item"><a href="/products">Produits</a></li>
          <li class="breadcrumb-item active">
            <%= product.name %>
          </li>
        </ol>
      </nav>

      <div class="row g-4">

        <!-- IMAGE -->
        <div class="col-lg-6">

          <% if (product.imageUrl) { %>
            <img src="/public/<%= product.imageUrl %>" class="img-fluid rounded shadow w-100"
              style="max-height:400px; object-fit:cover;">
            <% } else { %>
              <img src="https://via.placeholder.com/600x400?text=<%= product.name %>"
                class="img-fluid rounded shadow w-100" style="max-height:400px; object-fit:cover;">
              <% } %>

                <!-- BADGES -->
                <div class="mt-3">
                  <% if (product.stock < 10 && product.stock> 0) { %>
                    <span class="badge bg-warning">Stock limité</span>
                    <% } %>

                      <% if (product.price < 10000) { %>
                        <span class="badge bg-success">Bon plan</span>
                        <% } %>
                </div>

        </div>

        <!-- INFO -->
        <div class="col-lg-6">

          <h2>
            <%= product.name %>
          </h2>

          <h4 class="text-primary">
            <%= product.price %> FCFA
          </h4>

          <!-- STOCK FIXÉ (IMPORTANT) -->
          <div class="mb-3">
            <% let stockText='' ; let stockClass='' ; if (product.stock> 10) {
              stockText = 'En stock';
              stockClass = 'text-success';
              } else if (product.stock > 0) {
              stockText = 'Stock limité (' + product.stock + ' restants)';
              stockClass = 'text-warning';
              } else {
              stockText = 'Rupture de stock';
              stockClass = 'text-danger';
              }
              %>

              <span class="<%= stockClass %>">
                <%= stockText %>
              </span>
          </div>

          <p>
            <strong>Catégorie :</strong>
            <%= product.Category ? product.Category.name : 'Non catégorisé' %>
          </p>

          <!-- ADD TO CART -->
          <form method="POST" action="/products/cart/add">
            <input type="hidden" name="productId" value="<%= product.id %>">
            <input type="hidden" name="quantity" value="1">

            <button class="btn btn-primary w-100" <%=product.stock <=0 ? 'disabled' : '' %>>
              <%= product.stock <=0 ? 'Indisponible' : 'Ajouter au panier' %>
            </button>
          </form>

          <!-- CART -->
          <a href="/products/cart" class="btn btn-outline-secondary w-100 mt-2">
            Voir panier
          </a>

          <!-- WISHLIST -->
          <% if (user) { %>
            <button class="btn btn-outline-danger w-100 mt-2" onclick="toggleWishlist()">
              Favoris
            </button>
            <% } else { %>
              <a href="/auth/login" class="btn btn-outline-danger w-100 mt-2">
                Favoris
              </a>
              <% } %>

        </div>
      </div>

      <!-- DESCRIPTION -->
      <div class="mt-5">
        <h4>Description</h4>
        <p>
          <%= product.description || 'Aucune description disponible' %>
        </p>
      </div>

    </div>

    <%- include('partials/footer') %>

      <!-- JS -->
      <script>
        const productId = "<%= product.id %>";
        const userId = "<%= user ? user.id : null %>";

        async function toggleWishlist() {
          try {
            const res = await fetch('/wishlist/api/add', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ productId })
            });

            const data = await res.json();

            if (data.success) {
              alert("Ajouté aux favoris");
            } else {
              alert(data.error || "Erreur");
            }
          } catch (err) {
            console.error(err);
          }
        }
      </script>

</body>

</html>