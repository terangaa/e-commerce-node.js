<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('partials/head', { pageTitle: 'Accueil Ecommerce JIM' }) %>
</head>
<body>
  <%- include('partials/nav', { user, locale, currentPage: 'home' }) %>

  <section class="hero">
    <div class="container hero-wrap text-center">
      <h1>Bienvenue chez JIM Shopping</h1>
      <p>Trouve tes meilleures valises, chaussures, literie, et accessoires moto — livraison rapide et garanties qualité.</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg mr-2" href="/products">Découvrir</a>
        <a class="btn btn-outline-light btn-lg" href="/auth/register">Créer un compte</a>
      </div>
    </div>
  </section>

  <div class="container my-5">
    <h2 class="section-title">Catégories populaires</h2>
    <div class="row">
      <% categories.forEach(cat => { %>
        <div class="col-md-2 mb-4">
          <div class="category-card text-center p-3 h-100">
            <strong><%= cat.name %></strong>
            <p class="muted-text"><%= cat.description || 'Produits de qualité' %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="container my-4">
    <h2 class="section-title">Top produits</h2>
    <div class="row">
      <% topProducts.forEach(product => { %>
        <div class="col-md-3 mb-4">
          <div class="card h-100 shadow-sm">
            <% if(product.imageUrl){ %>
              <img src="<%= product.imageUrl %>" class="card-img-top" alt="<%= product.name %>">
            <% } else { %>
              <img src="https://via.placeholder.com/350x220?text=<%= product.name %>" class="card-img-top" alt="<%= product.name %>">
            <% } %>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= product.name %></h5>
              <p class="card-text text-muted"><%= product.description ? product.description.substring(0, 70) + (product.description.length > 70 ? '...' : '') : 'Aucune description' %></p>
              <div class="mt-auto">
                <p class="font-weight-bold mb-2"><%= product.price %> FCFA</p>
                <a href="/products/<%= product.id %>?lang=<%= locale %>" class="btn btn-sm btn-primary">Voir détails</a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="container section-card-wrap mb-5">
    <h2 class="section-title">Catégories</h2>
    <div class="row">
      <% categories.forEach(cat => { %>
        <div class="col-md-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= cat.name %></h5>
              <p class="card-text"><%= cat.description || 'Description non disponible' %></p>
              <p><strong>Produits :</strong> <%= cat.Products.length %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
