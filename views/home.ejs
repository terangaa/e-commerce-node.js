<!DOCTYPE html>
<html lang="<%= locale || 'fr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('partials/head', { pageTitle: 'Accueil Ecommerce JIM' }) %>
</head>
<body>
  <%- include('partials/nav', { user, locale, currentPage: 'home' }) %>

  <section class="hero">
    <div class="container hero-wrap text-center">
      <h1>Bienvenue chez JIM Shopping</h1>
      <p>Trouve tes meilleures valises, chaussures, literie et accessoires moto — livraison rapide et prix compétitifs.</p>
      <div class="hero-search row justify-content-center">
        <div class="col-lg-7 col-md-9">
          <form action="/products" method="get" class="d-flex gap-2">
            <input class="form-control" type="search" name="q" placeholder="Rechercher un produit, une catégorie ou une marque" aria-label="Rechercher" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
            <button class="btn btn-primary" type="submit"><i class="fa fa-search"></i> Rechercher</button>
          </form>
        </div>
      </div>
      <div class="hero-actions mt-4">
        <a class="btn btn-primary btn-lg me-2" href="/products">Voir les produits</a>
        <a class="btn btn-outline-primary btn-lg" href="/auth/register">Créer un compte</a>
      </div>
    </div>
  </section>

  <div class="container my-5">
    <h2 class="section-title">Catégories populaires</h2>
    <div class="row">
      <% categories.forEach(cat => { %>
        <div class="col-md-2 mb-4">
          <div class="category-card text-center p-3 h-100">
            <strong><%= cat.name %></strong>
            <p class="muted-text"><%= cat.description || 'Produits de qualité' %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="container my-4">
    <h2 class="section-title">Top produits</h2>
    <div class="row">
      <% topProducts.forEach(product => { %>
        <div class="col-md-3 mb-4">
          <div class="card h-100 shadow-sm">
            <% if(product.imageUrl){ %>
              <img src="<%= product.imageUrl %>" class="card-img-top" alt="<%= product.name %>">
            <% } else { %>
              <img src="https://via.placeholder.com/350x220?text=<%= product.name %>" class="card-img-top" alt="<%= product.name %>">
            <% } %>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= product.name %></h5>
              <p class="card-text text-muted"><%= product.description ? product.description.substring(0, 70) + (product.description.length > 70 ? '...' : '') : 'Aucune description' %></p>
              <div class="mt-auto">
                <p class="font-weight-bold mb-2"><%= product.price %> FCFA</p>
                <a href="/products/<%= product.id %>?lang=<%= locale %>" class="btn btn-sm btn-primary">Voir détails</a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="container section-card-wrap mb-5">
    <h2 class="section-title">Catégories</h2>
    <div class="row">
      <% categories.forEach(cat => { %>
        <div class="col-md-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= cat.name %></h5>
              <p class="card-text"><%= cat.description || 'Description non disponible' %></p>
              <p><strong>Produits :</strong> <%= cat.Products.length %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="container section-card-wrap mb-5">
    <h2 class="section-title">Contactez-nous</h2>
    <p>Besoin d’aide ou d’informations supplémentaires ? Envoyez votre message directement :</p>
    <form action="/contact" method="post">
      <div class="row g-3">
        <div class="col-md-4">
          <input type="text" name="name" class="form-control" placeholder="Nom" required />
        </div>
        <div class="col-md-4">
          <input type="email" name="email" class="form-control" placeholder="Email" required />
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-primary w-100">Envoyer le message</button>
        </div>
      </div>
      <div class="mt-3">
        <textarea name="message" class="form-control" rows="4" placeholder="Votre message" required></textarea>
      </div>
    </form>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
