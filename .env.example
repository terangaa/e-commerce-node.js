# ╔════════════════════════════════════════════════════════════════╗
# ║  E-COMMERCE JIM - CONFIGURATION ENVIRONNEMENT                  ║
# ║  Copiez ce fichier en .env et remplissez vos données           ║
# ╚════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════
# 🚀 SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
NODE_ENV=development
PORT=3000

# ═══════════════════════════════════════════════════════════════════
# 🔐 SESSION & SECURITY
# ═══════════════════════════════════════════════════════════════════
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ═══════════════════════════════════════════════════════════════════
# 💾 DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ecommerce_jim
DB_DIALECT=mysql

# ═══════════════════════════════════════════════════════════════════
# 📧 EMAIL SERVICE - GMAIL SMTP
# ═══════════════════════════════════════════════════════════════════
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-password
GMAIL_FROM_NAME=E-Commerce JIM

# ═══════════════════════════════════════════════════════════════════
# 📱 SMS SERVICE (TWILIO)
# ═══════════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════════════
# 💳 PAYMENT GATEWAY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
PAYMENT_API_KEY=your-payment-api-key

# ═══════════════════════════════════════════════════════════════════
# 🔑 SOCIAL AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ═══════════════════════════════════════════════════════════════════
# 🌐 CORS & DOMAIN CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
CORS_ORIGIN=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# 🎯 BUSINESS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
SHOP_NAME=E-Commerce JIM
SHOP_EMAIL=contact@ecommercejim.com
SHOP_PHONE=+221 77 XXX XXXX
CURRENCY=FCFA
CURRENCY_SYMBOL=FCFA

